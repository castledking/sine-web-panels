{
  "id": "sine-web-panels",
  "name": "Web Panels",
  "description": "Adds a lightweight web panel rail for quick access to saved web apps in Firefox-family browsers through Sine.",
  "author": "Tom Bar-Gal",
  "version": "0.2.0",
  "homepage": "https://github.com/dehyde/sine-web-panels",
  "style": {
    "chrome": "userChrome.css"
  },
  "preferences": "preferences.json",
  "supportsUnload": true,
  "scripts": {
    "scripts/web-panels-store.uc.mjs": {
      "include": [
        "chrome://browser/content/browser.xhtml"
      ],
      "loadOrder": 1
    },
    "scripts/web-panels-runtime.uc.mjs": {
      "include": [
        "chrome://browser/content/browser.xhtml"
      ],
      "loadOrder": 2
    },
    "scripts/web-panels.uc.mjs": {
      "include": [
        "chrome://browser/content/browser.xhtml"
      ],
      "loadOrder": 3
    }
  },
  "tags": [
    "web-panels",
    "sidebar",
    "chrome",
    "sine"
  ],
  "fork": [
    "firefox",
    "zen",
    "waterfox",
    "floorp",
    "librewolf"
  ]
}
